{
  "manifest_version": 3,
  "name": "Survev Customizer",
  "version": "2.0",
  "description": "Allow you to customize the game background splash art and audios.",
  "permissions": ["declarativeNetRequest"],
  "host_permissions": [
    "*://survev.io/*",
    "*://*.survev.io/*",
    "*://survev.de/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "web_accessible_resources": [
    {
      "resources": ["audio/*"],
      "matches": [
        "https://survev.io/*",
        "https://*.survev.io/*",
        "http://survev.de/*",
        "https://survev.de/*"
      ]
    }
  ]
}
